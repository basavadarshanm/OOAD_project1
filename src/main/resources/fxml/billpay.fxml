<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.onlinebanking.controller.PayBillsController" prefWidth="980.0" prefHeight="700.0" styleClass="billpay-root" stylesheets="@/styles/app.css">
    <top>
        <VBox spacing="8" styleClass="billpay-header">
            <Label text="Pay Bills" styleClass="billpay-title" />
            <Label fx:id="balanceLabel" styleClass="balance-pill" />
        </VBox>
    </top>
    <center>
        <VBox spacing="16" styleClass="billpay-content">
            <GridPane hgap="16" vgap="14" styleClass="form-grid">
                <columnConstraints>
                    <ColumnConstraints minWidth="170" prefWidth="190" />
                    <ColumnConstraints minWidth="320" hgrow="ALWAYS" />
                </columnConstraints>

                <Label text="Biller Name" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="billerField" promptText="Electric Company" styleClass="input-field" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                
                <Label text="Bill Reference" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <TextField fx:id="billRefField" promptText="e.g. ELEC123456" styleClass="input-field" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                
                <Label text="Amount (Rs.)" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="amountField" promptText="0.00" styleClass="input-field" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                
                <Label text="Due Date" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <DatePicker fx:id="dueDate" styleClass="input-field" GridPane.rowIndex="3" GridPane.columnIndex="1" />
            </GridPane>
            
            <HBox spacing="12">
                <Button text="Pay Bill" onAction="#handlePayBill" prefWidth="130" styleClass="btn-primary" />
                <Button text="Back" onAction="#handleBack" prefWidth="130" styleClass="btn-secondary" />
            </HBox>
            
            <Label fx:id="messageLabel" styleClass="message-label" />
            <TextArea fx:id="receiptArea" prefHeight="300" wrapText="true" editable="false" styleClass="receipt-area" />
        </VBox>
    </center>
</BorderPane>
