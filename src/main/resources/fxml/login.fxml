<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.onlinebanking.controller.LoginController">
    <center>
        <VBox spacing="10" alignment="CENTER">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="Online Banking Login" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <TextField fx:id="usernameField" promptText="Username" />
            <PasswordField fx:id="passwordField" promptText="Password" />
            <Button text="Login" onAction="#handleLogin" maxWidth="Infinity" />
            <Button text="Create account" onAction="#handleShowRegister" maxWidth="Infinity" />
            <Label fx:id="errorLabel" textFill="red" />
            <Label fx:id="infoLabel" textFill="green" />
        </VBox>
    </center>
</BorderPane>
