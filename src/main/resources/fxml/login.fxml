<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.onlinebanking.controller.LoginController" styleClass="auth-root">
    <center>
        <StackPane styleClass="auth-backdrop">
            <VBox spacing="16" alignment="CENTER" styleClass="auth-card" maxWidth="440">
                <padding>
                    <Insets top="34" right="34" bottom="30" left="34"/>
                </padding>
                <VBox spacing="10" alignment="CENTER">
                    <Label text="Online Banking" styleClass="auth-badge-text auth-badge" />
                    <Label text="Welcome back" styleClass="auth-title" />
                    <Label text="Sign in to manage your accounts, transfer money, and review transactions." styleClass="auth-subtitle" wrapText="true" alignment="CENTER" textAlignment="CENTER" />
                </VBox>
                <TextField fx:id="usernameField" promptText="Username" styleClass="auth-field" />
                <PasswordField fx:id="passwordField" promptText="Password" styleClass="auth-field" />
                <Button text="Login" onAction="#handleLogin" maxWidth="Infinity" styleClass="auth-primary-button" />
                <Button text="Create account" onAction="#handleShowRegister" maxWidth="Infinity" styleClass="auth-secondary-button" />
                <Label fx:id="errorLabel" styleClass="auth-message-error" wrapText="true" />
                <Label fx:id="infoLabel" styleClass="auth-message-info" wrapText="true" />
            </VBox>
        </StackPane>
    </center>
</BorderPane>
