<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.onlinebanking.controller.DashboardController" prefWidth="980.0" prefHeight="700.0" styleClass="dashboard-root" stylesheets="@/styles/app.css">
    <top>
        <VBox spacing="8" styleClass="dashboard-header">
            <Label fx:id="welcomeLabel" styleClass="dashboard-title" />
            <Label fx:id="accountLabel" styleClass="dashboard-subtitle" />
            <Label fx:id="balanceLabel" styleClass="dashboard-balance" />
        </VBox>
    </top>
    <center>
        <VBox spacing="10" styleClass="dashboard-content">
            <Label text="Recent Transactions" styleClass="section-title" />
            <Label fx:id="actionMessageLabel" styleClass="action-message" />
            <ListView fx:id="transactionsList" prefHeight="430" styleClass="tx-list" />
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10" styleClass="dashboard-actions">
            <Button fx:id="createAccountButton" text="Create Account" onAction="#handleCreateAccount" styleClass="btn-primary" />
            <Button fx:id="userDetailsButton" text="User Details" onAction="#handleUserDetails" styleClass="btn-primary" />
            <Button fx:id="addMoneyButton" text="Add Money" onAction="#handleAddMoney" styleClass="btn-success" />
            <Button fx:id="transferButton" text="Transfer Money" onAction="#handleTransfer" styleClass="btn-secondary" />
            <Button fx:id="billPayButton" text="Pay Bills" onAction="#handleBillPay" styleClass="btn-secondary" />
            <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-ghost" />
            <Button text="Logout" onAction="#handleLogout" styleClass="btn-ghost" />
        </HBox>
    </bottom>
</BorderPane>

