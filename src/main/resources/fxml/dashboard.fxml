<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.onlinebanking.controller.DashboardController">
    <top>
        <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label fx:id="welcomeLabel" style="-fx-font-size: 18px; -fx-text-fill: white; -fx-font-weight: bold;" />
            <Label fx:id="accountLabel" style="-fx-text-fill: #ecf0f1;" />
            <Label fx:id="balanceLabel" style="-fx-text-fill: #27ae60; -fx-font-size: 14px; -fx-font-weight: bold;" />
        </VBox>
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding: 15;">
            <Label text="Recent Transactions" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
            <ListView fx:id="transactionsList" prefHeight="250" />
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10" style="-fx-padding: 15; -fx-background-color: #ecf0f1;">
            <Button text="Transfer Money" onAction="#handleTransfer" style="-fx-font-size: 12px;" />
            <Button text="Pay Bills" onAction="#handleBillPay" style="-fx-font-size: 12px;" />
            <Button text="Refresh" onAction="#handleRefresh" style="-fx-font-size: 12px;" />
            <Button text="Logout" onAction="#handleLogout" style="-fx-font-size: 12px;" />
        </HBox>
    </bottom>
</BorderPane>

